# ==============================================================================
# Secure Messenger — Environment Variables Configuration Template
# ==============================================================================
# Copy this file to '.env' and fill in your custom keys before deploying.
# Make sure '.env' is excluded from your git repository to prevent leaks.
# ==============================================================================

# 1. JWT Session Secret Key (for signing JWT session tokens)
# Generate a secure random string using Python:
#   python -c "import secrets; print(secrets.token_hex(32))"
MESSENGER_JWT_SECRET=your_jwt_secret_hex_here

# 2. Database Record Encryption Key (AES-256-GCM symmetric key)
# Must be a 32-byte key represented as a 64-character hexadecimal string.
# Generate a secure hex key using Python:
#   python -c "import os; print(os.urandom(32).hex())"
MESSENGER_ENCRYPTION_KEY=your_encryption_key_hex_here
